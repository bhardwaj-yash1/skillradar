# === LLM Provider ===
# Switch between: groq, openrouter, openai
LLM_PROVIDER=groq

# === Groq (recommended default) ===
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-20b
GROQ_BASE_URL=https://api.groq.com/openai/v1

# === OpenRouter (free router option) ===
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=SkillRadar
OPENROUTER_HTTP_REFERER=http://localhost:8501

# === OpenAI (optional fallback) ===
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# === Database ===
DATABASE_URL=postgresql+asyncpg://skillradar:skillradar@localhost:5432/skillradar
SYNC_DATABASE_URL=postgresql://skillradar:skillradar@localhost:5432/skillradar
POSTGRES_USER=skillradar
POSTGRES_PASSWORD=skillradar
POSTGRES_DB=skillradar

# === Frontend / CORS ===
CORS_ORIGINS=["https://skillradar-rho.vercel.app","http://localhost:3000","http://127.0.0.1:3000"]
# Railway injects PORT automatically; set it only for local container testing.
# PORT=8000

# === Optional - Email (Resend) ===
RESEND_API_KEY=
EMAIL_FROM=SkillRadar <noreply@yourdomain.com>

# === App Settings (defaults shown) ===
DEBUG=false
LOG_LEVEL=INFO
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.0
MAX_JDS_PER_SCRAPE_RUN=50
SCRAPE_DELAY_MIN_SECONDS=2.0
SCRAPE_DELAY_MAX_SECONDS=5.0
WEEKLY_SCRAPE_DAY=monday
WEEKLY_SCRAPE_HOUR=2
WEEKLY_DIGEST_DAY=monday
WEEKLY_DIGEST_HOUR=9
